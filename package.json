{
  "name": "tapetaupe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Whack-a-mole arcade game (vanilla TS + Cloudflare Workers)",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --filter='@tapetaupe/web' dev",
    "dev:api": "bun run --filter='@tapetaupe/api' dev",
    "build": "bun run --filter='*' build",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html,yml,yaml,toml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "10.0.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-unicorn": "64.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.2",
    "prettier": "3.8.3",
    "typescript-eslint": "8.59.2"
  }
}
